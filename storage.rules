rules_version = '2';
// Firebase Storage в этом приложении не используется (картинки в Firestore).
// Если Storage включите случайно, доступ закрыт. Для лабораторной можно не трогать Storage.
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
